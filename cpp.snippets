template <typename T>
vector<T>& operator%=(vector<T>& a, const vector<T>& b) {
  int n = (int)a.size();
  int m = (int)b.size();
  if (n >= m) {
    vector<T> c = (a / b) * b;
    a.resize(m - 1);
    for (int i = 0; i < m - 1; i++) {
      a[i] -= c[i];
    }
  }
  return a;
}

